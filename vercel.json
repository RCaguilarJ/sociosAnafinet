{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/$",
      "dest": "/api/index.php?__vc_path=index.php"
    },
    {
      "src": "/afiliacion/?$",
      "dest": "/api/index.php?__vc_path=afiliacion/index.php"
    },
    {
      "src": "/(.*\\.php)$",
      "dest": "/api/index.php?__vc_path=$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
